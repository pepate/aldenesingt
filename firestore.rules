/**
 * Firestore Security Rules for SyncScroll Application
 * Prototyping Mode: Secure Authorization, Flexible Schema
 *
 * Core Philosophy:
 * This ruleset implements a mixed security model to balance user privacy with public accessibility.
 * User-specific data (profiles) is strictly confined to the user who created it.
 * A shared, public library of songs is available for anyone to read, but write access is restricted to the song's original author.
 * Collaborative sessions are managed by a designated 'host', who has full control over the session's lifecycle and participants.
 *
 * Data Structure:
 * - /users/{userId}: Private user profile data. Access is restricted to the owner.
 * - /songs/{songId}: A top-level collection for all publicly-readable songs.
 * - /sessions/{sessionId}: Contains data for a single collaborative session, controlled by the 'hostId'.
 * - /sessions/{sessionId}/sessionParticipants/{sessionParticipantId}: A subcollection tracking users who have joined a session.
 *
 * Key Security Decisions:
 * - Default Deny: All paths are closed by default. Access is granted explicitly.
 * - No User Listing: It is not possible to query the top-level `/users` collection, protecting user privacy.
 * - Public Read Access: The `/songs` collection is world-readable to allow browsing without authentication.
 * - Owner-Only Writes: All write operations (create, update, delete) require authentication and are restricted to the data's owner (e.g., a user for their profile, a host for their session, an author for their song).
 * - Self-Join for Sessions: Users can join an existing session by creating their own participant document. They can also remove themselves. The session host retains administrative control to remove any participant.
 *
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions for reusable logic

    /**
     * Returns true if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Returns true if the user's UID matches the provided userId.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * Returns true if a document exists and the user's UID matches the provided userId.
     * Used for safe update and delete operations.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * Returns true if the user is the host of the specified session.
     * Requires a get() call to the parent session document.
     */
    function isHost(sessionId) {
      return get(/databases/$(database)/documents/sessions/$(sessionId)).data.hostId == request.auth.uid;
    }

    /**
     * Returns true if the session document data indicates the user is the host.
     */
    function isHostOf(sessionDocData) {
      return sessionDocData.hostId == request.auth.uid;
    }

    /**
     * Returns true if the session document exists and the user is the host.
     * Used for safe session update and delete operations.
     */
    function isExistingHostOf(sessionDocData) {
      return isHostOf(sessionDocData) && resource != null;
    }

    /**
     * @description Manages user profile documents.
     * @path /users/{userId}
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Manages the public library of songs.
     * @path /songs/{songId}
     */
    match /songs/{songId} {
        allow read: if true;
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    /**
     * @description Manages collaborative viewing sessions.
     * @path /sessions/{sessionId}
     */
    match /sessions/{sessionId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.hostId == request.auth.uid;
      allow update: if isExistingHostOf(resource.data) && request.resource.data.hostId == resource.data.hostId;
      allow delete: if isExistingHostOf(resource.data);

      /**
       * @description Manages participants within a session.
       * @path /sessions/{sessionId}/sessionParticipants/{sessionParticipantId}
       */
      match /sessionParticipants/{sessionParticipantId} {
        allow get: if isSignedIn();
        allow list: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && request.resource.data.sessionId == sessionId;
        allow update: if false;
        allow delete: if resource != null && (isOwner(resource.data.userId) || isHost(sessionId));
      }
    }
  }
}

/**
 * @description Firebase Storage Security Rules
 * These rules govern access to files stored in Firebase Storage.
 */
service firebase.storage {
  match /b/{bucket}/o {
    /**
     * @description Manages user-specific documents.
     * @path /documents/{userId}/{allPaths=**}
     */
    match /documents/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
