/**
 * Firestore Security Rules for SyncScroll Application
 * Prototyping Mode: Secure Authorization, Flexible Schema
 *
 * Core Philosophy:
 * This ruleset implements a mixed security model to balance user privacy with public accessibility.
 * User-specific data (profiles, private documents) is strictly confined to the user who created it.
 * A shared, public library of documents is available for anyone to read, but write access is restricted to the document's original author.
 * Collaborative sessions are managed by a designated 'host', who has full control over the session's lifecycle and participants.
 *
 * Data Structure:
 * - /users/{userId}: Private user profile data. Access is restricted to the owner.
 * - /users/{userId}/pdf_documents/{pdfDocumentId}: A user's private collection of documents. This is structurally segregated from the public library to ensure privacy.
 * - /pdf_documents/{pdfDocumentId}: A top-level collection for all publicly-readable documents. This allows for efficient, unauthenticated browsing.
 * - /sessions/{sessionId}: Contains data for a single collaborative session, controlled by the 'hostId'.
 * - /sessions/{sessionId}/sessionParticipants/{sessionParticipantId}: A subcollection tracking users who have joined a session.
 *
 * Key Security Decisions:
 * - Default Deny: All paths are closed by default. Access is granted explicitly.
 * - No User Listing: It is not possible to query the top-level `/users` collection, protecting user privacy.
 * - Public Read Access: The `/pdf_documents` collection is world-readable to allow browsing without authentication, as requested.
 * - Owner-Only Writes: All write operations (create, update, delete) require authentication and are restricted to the data's owner (e.g., a user for their profile, a host for their session, an author for their document).
 * - Self-Join for Sessions: Users can join an existing session by creating their own participant document. They can also remove themselves. The session host retains administrative control to remove any participant.
 *
 * Denormalization for Authorization:
 * To ensure fast and secure rules, ownership is denormalized directly onto documents.
 * - `PdfDocument` and `Session` documents contain `userId` and `hostId` fields respectively. This allows rules to check ownership without expensive `get()` calls to other documents.
 * - `sessionParticipants` rules use one `get()` call to the parent `session` document to verify the host, which is an efficient and necessary pattern for subcollection security.
 *
 * Structural Segregation:
 * Private user documents (`/users/{userId}/pdf_documents`) are stored in a separate collection from public documents (`/pdf_documents`). This is more secure and performant than using a single collection with a boolean `isPublic` flag, especially for list queries.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions for reusable logic

    /**
     * Returns true if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Returns true if the user's UID matches the provided userId.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * Returns true if a document exists and the user's UID matches the provided userId.
     * Used for safe update and delete operations.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * Returns true if the user is the host of the specified session.
     * Requires a get() call to the parent session document.
     */
    function isHost(sessionId) {
      return get(/databases/$(database)/documents/sessions/$(sessionId)).data.hostId == request.auth.uid;
    }

    /**
     * Returns true if the session document data indicates the user is the host.
     */
    function isHostOf(sessionDocData) {
      return sessionDocData.hostId == request.auth.uid;
    }

    /**
     * Returns true if the session document exists and the user is the host.
     * Used for safe session update and delete operations.
     */
    function isExistingHostOf(sessionDocData) {
      return isHostOf(sessionDocData) && resource != null;
    }

    /**
     * @description Manages user profile documents.
     * @path /users/{userId}
     * @allow (create) An authenticated user creating their own profile document, e.g., POST /users/user_abc with auth.uid = 'user_abc'.
     * @deny (get) A user trying to read another user's profile, e.g., GET /users/user_xyz with auth.uid = 'user_abc'.
     * @deny (list) Any attempt to list all users in the collection.
     * @principle Restricts access to a user's own data tree.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Manages a user's private PDF documents.
       * @path /users/{userId}/pdf_documents/{pdfDocumentId}
       * @allow (create) The owner creating a new private document under their own path.
       * @deny (get) Any user trying to access another user's private documents.
       * @principle Enforces strict document ownership within a user's private data tree.
       */
      match /pdf_documents/{pdfDocumentId} {
        allow read, write: if isOwner(userId);
      }
    }

    /**
     * @description Manages the public library of PDF documents.
     * @path /pdf_documents/{pdfDocumentId}
     * @allow (get, list) Any user, including unauthenticated ones, can read and list all public documents.
     * @allow (create) An authenticated user uploading a new document and setting themselves as the owner.
     * @deny (update) A user trying to modify a document they did not upload.
     * @principle Public Read with Owner-Only Writes.
     */
    match /pdf_documents/{pdfDocumentId} {
        allow read: if true;
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    /**
     * @description Manages collaborative viewing sessions.
     * @path /sessions/{sessionId}
     * @allow (create) An authenticated user creating a new session and setting themselves as the host.
     * @allow (get, list) Any authenticated user can read or list available sessions.
     * @deny (update) A user who is not the session host trying to change the scroll position or other details.
     * @principle Enforces "host" ownership for writes, while allowing reads for participants.
     */
    match /sessions/{sessionId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.hostId == request.auth.uid;
      allow update: if isExistingHostOf(resource.data) && request.resource.data.hostId == resource.data.hostId;
      allow delete: if isExistingHostOf(resource.data);

      /**
       * @description Manages participants within a session.
       * @path /sessions/{sessionId}/sessionParticipants/{sessionParticipantId}
       * @allow (create) A signed-in user adding themselves to a session.
       * @allow (delete) A participant removing themselves, OR the session host removing any participant.
       * @deny (update) No updates are allowed to participant records; they must be deleted and re-created.
       * @principle Allows self-joining and self-removal, with host override.
       */
      match /sessionParticipants/{sessionParticipantId} {
        allow get: if isSignedIn();
        allow list: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && request.resource.data.sessionId == sessionId;
        allow update: if false;
        allow delete: if resource != null && (isOwner(resource.data.userId) || isHost(sessionId));
      }
    }
  }
}
