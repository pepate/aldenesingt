/**
 * Firestore Security Rules for SyncScroll Application
 * Role-Based Access Control: Secure by Default
 *
 * Core Philosophy:
 * This ruleset implements a role-based access control (RBAC) system to manage user permissions.
 * It now supports anonymous users for viewing and joining sessions.
 *
 * Roles:
 * - 'user': Can view/join sessions. Can "upgrade" to a permanent account. Includes anonymous users.
 * - 'creator': Can do everything a 'user' can, plus create sessions and generate a limited number of new songs per day.
 * - 'admin': Has full access, including the ability to manage user roles and create sessions.
 *
 * Data Structure & Access:
 * - /users/{userId}: Private user profile, contains the 'role'.
 *   - Users can read their own profile.
 *   - Admins can read and write to any profile (to manage roles).
 *   - Users can update their own profile but are NOT allowed to change their own role.
 * - /songs/{songId}: Publicly-readable songs.
 *   - Reading is allowed by everyone (including anonymous).
 *   - Creating songs is restricted to 'creator' and 'admin' roles.
 *   - Updating/Deleting a song is restricted to the original author.
 * - /sessions/{sessionId}: Collaborative sessions.
 *   - Reading and listing is public for all users (including anonymous).
 *   - Session creation is restricted to 'creator' and 'admin' roles.
 *   - Managed by a 'host', who has full control over updating the session (scroll, transpose).
 *
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions for reusable logic

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function isRole(role) {
        // Check for isSignedIn is important because anonymous users will have a UID
        // but their user document might not exist yet or they may not have a role.
        // For our case, we assume a user doc is created with a default 'user' role.
        return isSignedIn() && getUserData(request.auth.uid).role == role;
    }

    function isAdmin() {
        return isRole('admin');
    }

    function isCreatorOrAdmin() {
        return isSignedIn() && (isRole('creator') || isRole('admin'));
    }

    function isHost(sessionId) {
      return get(/databases/$(database)/documents/sessions/$(sessionId)).data.hostId == request.auth.uid;
    }

    /**
     * @description Manages user profile documents.
     * @path /users/{userId}
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if false; // Prevent listing all users
      // Allow creation for any signed-in user (including anonymous users getting their profile doc created)
      allow create: if isOwner(userId);
      // Allow update if user is an admin, OR if the user is the owner and is NOT changing their own role.
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role);
      allow delete: if isAdmin() || isOwner(userId);
    }

    /**
     * @description Manages the public library of songs.
     * @path /songs/{songId}
     */
    match /songs/{songId} {
        // All users, including anonymous, can read songs
        allow read: if true;
        // Creation is restricted to users with 'creator' or 'admin' role.
        allow create: if isCreatorOrAdmin() && request.resource.data.userId == request.auth.uid;
        // Only the original author can update or delete their song.
        allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    /**
     * @description Manages collaborative viewing sessions.
     * @path /sessions/{sessionId}
     */
    match /sessions/{sessionId} {
      // Anyone can see the list of sessions and view a specific session's details
      allow get, list: if true;
      // Session creation is limited to creators and admins
      allow create: if isCreatorOrAdmin() && request.resource.data.hostId == request.auth.uid;
      // Only the host can update the session (scroll, transpose, song change)
      allow update: if isSignedIn() && isHost(sessionId);
      // Only the host can delete the session
      allow delete: if isSignedIn() && isHost(sessionId);

      /**
       * @description Manages participants within a session.
       * @path /sessions/{sessionId}/sessionParticipants/{sessionParticipantId}
       */
      match /sessionParticipants/{sessionParticipantId} {
        // Anyone can see who is in a session
        allow get, list: if true;
        // Any signed-in user (including anonymous) can join a session
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && request.resource.data.sessionId == sessionId;
        allow update: if false;
        // A user can leave, or the host can remove them.
        allow delete: if resource != null && (isOwner(resource.data.userId) || isHost(sessionId));
      }
    }
  }
}
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
