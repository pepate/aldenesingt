# This file is a template for your local development environment.
# Copy this file to .env.local and fill in your secret values.
# IMPORTANT: .env.local is ignored by Git and must never be committed.

# Get this configuration object from your Firebase project settings.
# Go to Project Settings > General > Your apps > Web app, and copy the `firebaseConfig` object.
# It must be a single line of JSON.
NEXT_PUBLIC_FIREBASE_CONFIG={"apiKey":"...","authDomain":"...","projectId":"...","storageBucket":"...","messagingSenderId":"...","appId":"..."}

# For local AI development with Genkit, you may need to authenticate via the gcloud CLI.
# Run `gcloud auth application-default login` in your terminal.
# The GEMINI_API_KEY is not typically needed if you use Application Default Credentials.
# GEMINI_API_KEY=
